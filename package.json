{
  "name": "contas",
  "version": "0.1.15",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "node scripts/load-secrets.js && next start",
    "start:docker": "node scripts/load-secrets.js && node server.js",
    "docker:build": "docker build -t angelomoreirafilho/gestao-contas:0.1.14 .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f contas_app",
    "swarm:init": "docker swarm init",
    "swarm:deploy": "docker stack deploy -c docker-compose.yml contas",
    "swarm:deploy:prod": "docker stack deploy -c docker-compose.yml -c docker-compose.prod.yml contas",
    "swarm:remove": "docker stack rm contas",
    "swarm:status": "docker service ls | grep contas"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.678.0",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.47.10",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.503.0",
    "next": "16.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-is": "^19.1.0",
    "recharts": "^3.0.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.9",
    "typescript": "^5.8.3"
  }
}
