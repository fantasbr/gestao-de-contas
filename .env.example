# ============================================
# Exemplo de Variáveis de Ambiente
# ============================================
# Copie para .env.local para desenvolvimento local
# Para Docker Swarm, use .env.swarm e secrets/

# ============================================
# SUPABASE (obrigatório)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
# Nao copie segredos server-only para .env.local.
# Injete SUPABASE_SERVICE_ROLE_KEY apenas no host/CI ou via Docker Secrets quando realmente necessario.


# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# NODE (produção)
# ============================================
NODE_ENV=production
